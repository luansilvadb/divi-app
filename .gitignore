# Secure and Complete Gitignore for Divi Project
# Created: 2026-04-01

# General Rules
!**/.gitkeep

# Security & Secrets
.env*
*.key
*.pem
*.p12
secrets.json
.credentials/

# Dependencies
node_modules/
pnpm-lock.yaml
package-lock.yaml

# Build Outputs
dist/
build/
out/
dev-dist/

# Logs & Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase Local Dev
.supabase/functions/.import_map.json

# OS Specifics
.DS_Store
Thumbs.db
desktop.ini

# IDE Specifics
.idea/
*.swp
.vscode/*
!.vscode/extensions.json

# Local Databases
*.db
*.sqlite
