{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.ts",
    "src/sw.ts"
  ],
  "project": [
    "src/**/*.{ts,vue}"
  ],
  "ignore": [
    "src/__tests__/**",
    "src/**/__tests__/**",
    "src/**/*.spec.ts"
  ],
  "ignoreDependencies": [
    "workbox-strategies",
    "workbox-expiration"
  ],
  "ignoreBinaries": [],
  "paths": {
    "@/*": ["src/*"]
  },
  "ignoreExportsUsedInFile": true
}
